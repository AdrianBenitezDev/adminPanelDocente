# Puerto del servidor
PORT=3000

# Seguridad opcional del endpoint /api/admin/users
ADMIN_PANEL_KEY=tu-clave-admin

# Colecciones Firestore que quieres revisar por cada UID (separadas por coma)
USER_COLLECTIONS=users,docentes

# Opcion A: JSON completo de la cuenta de servicio (una linea)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ...}

# Opcion B: Ruta al archivo JSON de la cuenta de servicio
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
