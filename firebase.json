{
  "functions": [
    {
      "source": "functions",
      "codebase": "adminpanel"
    }
  ],
  "hosting": [
    {
      "target": "adminpanel",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/admin/users/**",
          "function": "api"
        },
        {
          "source": "/api/admin/users",
          "function": "api"
        },
        {
          "source": "/health",
          "function": "api"
        },
        {
          "source": "**",
          "destination": "/admin.html"
        }
      ]
    }
  ]
}
